{
  "name": "@ycroaster/mcp",
  "version": "0.1.0",
  "description": "MCP server for YC Roaster — roast and coach Y Combinator application drafts.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "ycroaster-mcp": "dist/stdio.js"
  },
  "files": [
    "dist",
    "reference"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
